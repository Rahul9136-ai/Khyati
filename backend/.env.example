# Copy to .env. Never commit real secrets.
ENVIRONMENT=local
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-of-32+bytes

# Database backend: postgres (default) or sqlite (zero-infra dev/tests)
DB_BACKEND=postgres
SQLITE_PATH=wfm_dev.db

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wfm
POSTGRES_PASSWORD=wfm
POSTGRES_DB=wfm

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5180

# AI assistant (optional — deterministic fallbacks used when unset)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
